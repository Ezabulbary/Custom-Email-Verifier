# --- Backend environment variables ---
# Copy to `.env` and fill in real values:  cp .env.example .env

# Run mode. Keep 'development' for local runs. Set to 'production' ONLY on your
# live server — in production JWT_SECRET becomes mandatory (the server refuses
# to start without it) so tokens can't be forged with a guessable default.
NODE_ENV=development

# Port the API listens on (nginx proxies to this).
PORT=3001

# Required when NODE_ENV=production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# NOTE: `node server.js` does not auto-load this file. Either export these vars
# in your shell / process manager, or run with:  node --env-file=.env server.js
# (Node 20+).

# Comma-separated list of allowed browser origins for CORS. Leave EMPTY for
# local development (allows all). On your live server set it to your frontend
# URL, e.g. CORS_ORIGINS=https://verifier.yourdomain.com
CORS_ORIGINS=

# Frontend URL used to build the password-reset link in the email.
# Local dev default is http://localhost:5173; set to your live frontend origin.
FRONTEND_URL=http://localhost:5173

# --- Password-reset email ---
# Reset emails are sent via SMTP (nodemailer, already built in). Set these and
# real emails go out automatically; leave them blank and the reset link is just
# printed to the backend console (fine for local testing). See SETUP.md §6.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com,
# SMTP_PASS=<16-char app password>  (https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=BounceCure <no-reply@yourdomain.com>

# Roles: superadmin > admin > user.
# - The VERY FIRST registered account automatically becomes superadmin.
# - SUPERADMIN_EMAIL: this account is promoted to superadmin on startup.
# - ADMIN_EMAIL: this account is promoted to admin on startup.
# (Both work for already-registered users too.)
# Superadmins are visible only to superadmins; admins are visible to admins and
# superadmins; regular users are visible to admins and superadmins.
SUPERADMIN_EMAIL=
ADMIN_EMAIL=

# Set to 1 ONLY if you intentionally verify against a mail server on a private/
# internal IP. Leave unset in normal deployments (SSRF protection stays on).
# ALLOW_PRIVATE_MX=

# --- Google sign-in (OPTIONAL) ---
# Only needed to enable the "Continue with Google" button. If left blank, Google
# sign-in is simply disabled and email/password keeps working. See SETUP.md.
#
# Paste the Firebase service-account JSON (one line, from Firebase console →
# Project settings → Service accounts → Generate new private key):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}
#
# ...OR point to the downloaded file instead of pasting JSON:
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
