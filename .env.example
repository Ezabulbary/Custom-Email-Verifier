# --- Backend environment variables ---
# Copy to `.env` and fill in real values:  cp .env.example .env

# Run mode. Keep 'development' for local runs. Set to 'production' ONLY on your
# live server — in production JWT_SECRET becomes mandatory (the server refuses
# to start without it) so tokens can't be forged with a guessable default.
NODE_ENV=development

# Port the API listens on (nginx proxies to this).
PORT=3001

# Required when NODE_ENV=production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# NOTE: `node server.js` does not auto-load this file. Either export these vars
# in your shell / process manager, or run with:  node --env-file=.env server.js
# (Node 20+).

# Comma-separated list of allowed browser origins for CORS. Leave EMPTY for
# local development (allows all). On your live server set it to your frontend
# URL, e.g. CORS_ORIGINS=https://verifier.yourdomain.com
CORS_ORIGINS=

# Super admin account. The account with this email becomes admin on startup
# (works for an already-registered user too). The very first registered user
# also becomes admin automatically if no ADMIN_EMAIL is set.
ADMIN_EMAIL=

# Set to 1 ONLY if you intentionally verify against a mail server on a private/
# internal IP. Leave unset in normal deployments (SSRF protection stays on).
# ALLOW_PRIVATE_MX=
