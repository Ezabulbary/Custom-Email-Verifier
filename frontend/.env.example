# --- Frontend environment variables (Vite) ---
# Copy to `frontend/.env` and fill in real values:  cp frontend/.env.example frontend/.env
# Vite only exposes vars that start with VITE_. Restart `npm run dev` after edits.

# Where the backend API lives. Leave as-is for local dev. In production set it to
# your API origin, e.g. https://api.yourdomain.com  (or '' if same-origin behind nginx).
VITE_API_URL=http://localhost:3001

# --- Google sign-in (OPTIONAL) ---
# Only needed for the "Continue with Google" button. If left blank, the button
# shows a "needs Firebase" hint and email/password still works. See SETUP.md.
# Copy these from Firebase console → Project settings → General → Your apps → Web app → SDK config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
