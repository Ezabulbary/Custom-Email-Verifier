# --- Frontend environment variables (Vite) ---
# Copy to `frontend/.env` and fill in real values:  cp frontend/.env.example frontend/.env
# Vite only exposes vars that start with VITE_. Restart `npm run dev` after edits.

# Where the backend API lives.
# LOCAL DEV: leave this EMPTY. Requests then go through Vite's dev proxy
# (vite.config.js) to the backend on port 3001 — no CORS or localhost/IPv6 issues.
# PRODUCTION: set it to your API origin, e.g. https://api.yourdomain.com
# (or leave empty if the API is same-origin behind nginx).
VITE_API_URL=

# --- Google sign-in (OPTIONAL) ---
# Only needed for the "Continue with Google" button. If left blank, email/password
# still works. See SETUP.md. Copy these from Firebase console.
# Copy these from Firebase console → Project settings → General → Your apps → Web app → SDK config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
